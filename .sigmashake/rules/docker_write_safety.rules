# docker_write_safety.rules
# Technology: docker | Capability: write

rule docker-run-as-root {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/Dockerfile*" AND content NOT LINE_REGEX "(?i)USER\\s+[a-zA-Z0-9_]+"
  MESSAGE "Running containers as root is a major security risk. If a container breakout occurs, the attacker gains host root privileges. Always specify a non-root USER in the Dockerfile."
}

rule docker-privileged-mode {
  enabled true
  priority 100
  severity error
  DENY write
  IF path GLOB "**/docker-compose.yml" AND content LINE_REGEX "privileged\\s*:\\s*true"
  OR path GLOB "**/*.sh" AND content LINE_REGEX "docker\\s+run.*--privileged"
  MESSAGE "Running containers in privileged mode disables nearly all isolation and allows the container full access to the host machine. This is extremely dangerous and almost never necessary."
}

rule docker-expose-socket {
  enabled true
  priority 98
  severity error
  DENY write
  IF path GLOB "**/docker-compose.yml" AND content LINE_REGEX "-\\s*[\"']?/var/run/docker\\.sock:/var/run/docker\\.sock[\"']?"
  OR path GLOB "**/*.sh" AND content LINE_REGEX "-v\\s+[\"']?/var/run/docker\\.sock:/var/run/docker\\.sock[\"']?"
  MESSAGE "Mounting the Docker socket (/var/run/docker.sock) inside a container gives it full control over the host's Docker daemon, equivalent to root access on the host."
}

rule docker-latest-tag {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/Dockerfile*" AND content LINE_REGEX "(?i)FROM\\s+[a-zA-Z0-9_/-]+:latest"
  MESSAGE "Using the ':latest' tag for base images breaks immutability and can introduce supply chain vulnerabilities or breaking changes unexpectedly. Pin to a specific version or SHA256 digest."
  PROMPT "Are you sure you want to use the ':latest' tag? Pinning versions is much safer."
}
